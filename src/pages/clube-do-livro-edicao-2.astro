---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import obraA from "../assets/images/clube-do-livro/livro-uma-duas-eliane-brum.webp";
import obraB from "../assets/images/clube-do-livro/livro-a-vida-real-adeline-dioudonne.webp";
import obraC from "../assets/images/clube-do-livro/livro-leme-madalena-sa-fernandes.webp";
import obraD from "../assets/images/clube-do-livro/livro-saboroso-cadaver-augustina-bazterrica.webp";

import capaDororidade from "../assets/images/clube-do-livro/livro-dororidade.jpg";

import mediadoraFlavia from "../assets/images/clube-do-livro/flavia.jpg";
import mediadoraRenata from "../assets/images/clube-do-livro/renata.jpg";

const obras = [
  {
    src: obraA,
    alt: "Uma, duas - Eliane Brum (Brasil)",
    caption: "Uma, duas",
    author: "Eliane Brum (Brasil)",
    month: "Agosto",
  },
  {
    src: obraC,
    alt: "Leme - Madalena Sá Fernandes (Portugal) ",
    caption: "Leme",
    author: "Madalena Sá Fernandes (Portugal)",
    month: "Setembro",
  },
  {
    src: obraB,
    alt: "A Vida Real - Adeline Dieudonné (Bélgica)",
    caption: "A Vida Real",
    author: "Adeline Dieudonné (Bélgica)",
    month: "Outubro",
  },
  {
    src: obraD,
    alt: "Saboroso Cadáver - Agustina Bazterrica (Argentina)",
    caption: "Saboroso Cadáver",
    author: "Agustina Bazterrica (Argentina)",
    month: "Novembro",
  },
];

const testimonials = [
  {
    quote:
      "A literatura sempre ocupou um lugar especial na minha vida. Com as exigências da vida adulta, fui diminuindo o ritmo das leituras. Participar do Clube do Livro acenou para mim como uma oportunidade de retomar esse hábito...",
    body: "A curadoria dos livros é cuidadosa, a coordenação dos encontros feita pela Renata e pela Flávia é atenta e sensível, e as reflexões compartilhadas trazem alma, calor humano e pertencimento. Sem falar que estamos colaborando para esse potente projeto do Instituto ELAborar.",
    name: "Cláudia Guerra",
  },
  {
    quote:
      "Amei poder participar de um projeto tão incrível. A qualidade dos materiais desenvolvidos mostra que tudo foi pensado com muito carinho.",
    body: "O clube do livro vai além da leitura: é uma oportunidade de troca e conexão. Me senti honrada de participar, mesmo à distância. Que mais mulheres tenham a oportunidade de enriquecer sua visão sobre o mundo e fortalecer vínculos.",
    name: "Malucy Macedo",
  },
  {
    quote: "Participar do ELAborando Mulheridades tem sido muito gratificante.",
    body: "O projeto reúne mulheres de diferentes idades e experiências. Os encontros são conduzidos com maestria, conectando literatura, filmes, séries e diferentes linguagens. Uma experiência rica de trocas e reflexões sobre o universo feminino.",
    name: "Natália Maria Poock Delavequia",
  },
  {
    quote: "Participar do clube do livro tem sido uma experiência incrível.",
    body: "As mediadoras conduzem tudo com muito cuidado e sensibilidade, transformando os encontros em momentos de troca, reflexão e acolhimento. A organização e a forma como tudo acontece fazem toda a diferença.",
    name: "Dorvalina Moraes",
  },
  {
    quote:
      "Participar do Clube do Livro tem sido uma excelente oportunidade de ocupar um espaço de escuta, troca e reflexão entre mulheres.",
    body: "A cada encontro somos convidadas a olhar para temas profundos, ampliar compreensões e fortalecer a consciência sobre a defesa dos direitos das mulheres. Uma experiência potente, acolhedora e transformadora.",
    name: "Mariana Carvalho Silveira",
  },
  {
    quote:
      "Participar do Clube do Livro ELAborando Mulheridades tem sido uma experiência muito enriquecedora.",
    body: "Adorei a seleção de livros e os encontros muito bem moderados. São momentos genuínos de troca, escuta e acolhimento. Saímos de cada reunião com novas perspectivas e a sensação de pertencer a um espaço especial.",
    name: "Ana Carolina Prado Souza",
  },
];
---

<Layout>
  <div class="mb-28">
    <!-- HERO SECTION  -->
    <section class="relative overflow-hidden bg-secondary-100">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-24 pb-28">
        <div class="flex flex-col items-center text-center space-y-8">
          <p class="text-5xl tracking-tighter text-secondary-600">
            Clube do Livro · 2ª Edição
          </p>

          <h1
            class="text-5xl sm:text-6xl lg:text-7xl tracking-tighter text-primary-600"
          >
            ELAborando Mulheridades
          </h1>

          <p
            class="text-xl lg:text-2xl text-primary-700 max-w-2xl leading-snug tracking-tight"
          >
            Um convite ao encontro, à pausa e a ELAboração
          </p>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28 bg-white">
      <div class="px-4 max-w-3xl mx-auto text-center space-y-8">
        <blockquote class="space-y-4">
          <p
            class="text-2xl lg:text-3xl font-light text-primary-800 leading-snug tracking-tight"
          >
            "Você acha que não fala a mesma língua, mas então se dá conta de que
            a dor é a língua. Nós que temos passados conturbados nos
            entendemos."
          </p>
          <cite
            class="block text-primary-400 text-sm font-medium uppercase tracking-widest not-italic"
          >
            Elif Shafak
          </cite>
        </blockquote>

        <div class="w-12 h-px bg-primary-200 mx-auto"></div>

        <p class="text-primary-700 text-lg leading-relaxed">
          A nossa comunicação se encontra na dor que nasce da violência,
          simplesmente, por sermos mulheres. Mas nasce também na audácia de
          escutar a própria voz e na força de lutar coletivamente contra essa
          violência para renascer.
        </p>
      </div>
    </section>

    <!-- SOBRE A EDIÇÃO -->
    <section class="mx-auto py-20 lg:py-32  bg-primary-50">

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 ">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-5">
          <div class="sticky top-32">
            <p
              class="text-sm uppercase tracking-[0.25em] font-semibold text-primary-500 mb-4"
            >
              Sobre a edição
            </p>
            <h2
              class="text-3xl lg:text-4xl text-primary-600 leading-tighter tracking-tighter"
            >
              A travessia continua, agora com um tema que não nos deixa esquivar
            </h2>
          </div>
        </div>

        <div
          class="lg:col-span-7 lg:col-start-6 space-y-6 text-lg leading-relaxed text-primary-800/90"
        >
          <p class="text-lg leading-relaxed text-primary-900">
            A primeira edição do Clube do Livro ELAborando Mulheridades reuniu
            quase 30 mulheres de diferentes regiões do Brasil, de diferentes
            gerações e experiências. Juntas, percorremos uma travessia entre o
            sul e o norte global, atravessando culturas, literaturas e
            linguagens, num processo vivo de expansão de consciência, empatia,
            (auto)cuidado e conhecimento. Criamos um espaço em que mulheres de
            diferentes trajetórias ampliaram perspectivas, transformaram leitura
            em compreensão e descobriram que não estavam sozinhas.
          </p>
          <p class="text-lg leading-relaxed text-primary-900">
            A segunda edição segue essa travessia. Mas agora com um tema que não
            nos deixa esquivar: a violência contra a mulher, em suas diferentes
            facetas.
          </p>
          <p class="text-lg leading-relaxed text-primary-900">
            Sabemos que não é fácil. E é exatamente por isso que escolhemos
            encará-lo juntas, pela literatura. Sabemos que precisamos de tempo,
            linguagem e companhia para compreender experiências complexas.
            Porque os índices de violência contra mulheres e meninas seguem
            crescendo. Porque o silêncio não nos protege. Porque entendemos que
            nomear, narrar e partilhar é também uma forma de resistir. E porque
            mais do que respostas prontas, precisamos ampliar a capacidade de
            enxergar situações e fazer escolhas com mais clareza.
          </p>
          <p class="text-lg leading-relaxed text-primary-900">
            Nesta edição, saímos da esfera íntima e relacional e mergulhamos na
            estrutura contemporânea e no mal-estar entranhado nas práticas
            sociais. A literatura não resolve. Mas revela. E revelar, juntas, já
            é um começo.
          </p>
        </div>
      </div>
    </section>
    </section>

    <!-- OBRAS -->
    <section class="mx-auto p-20 lg:py-32">
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10 text-center"
      >
        <h2
          class="text-3xl lg:text-4xl font-semibold text-primary-700 tracking-tighter"
        >
          Sobre as obras
        </h2>

        <div
          class="max-w-4xl mx-auto space-y-6 text-primary-900 leading-relaxed tracking-tight pb-8"
        >
          <p class="text-xl">
            Quatro livros. Quatro escritoras. Quatro países. Uma escalada que
            começa no vínculo mais íntimo da maternidade e atravessa diferentes
            formas de violência até chegar à distopia, onde a literatura
            radicaliza o real para que possamos imaginar, criar e transformar.
          </p>
          <p class="text-xl">Os livros, na ordem da travessia:</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-2">
          {
            obras.map((obra) => (
              <div class="text-center">
                <div class="w-full overflow-hidden rounded-lg shadow-md mb-6">
                  <Image
                    src={obra.src}
                    alt={obra.alt}
                    class="w-full h-full object-cover"
                  />
                </div>

                <p class="font-semibold text-lg text-primary-900 mb-1">
                  {obra.caption}
                </p>
                <p class="text-primary-900  mb-1">{obra.author}</p>

                <p class="text-sm">{obra.month}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- UMA LENTE PARA A TRAVESSIA -->
    <section
      class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6 py-20 lg:py-32"
    >
      <!-- Layout duas colunas: capa + texto -->
      <div class="flex flex-col sm:flex-row gap-12 items-start">
        <Image
          src={capaDororidade}
          alt="Capa do livro Dororidade, de Vilma Piedade"
          class="w-36 sm:w-64 rounded shadow-sm shrink-0 mx-auto sm:mx-0"
        />
        <div class="space-y-4">
          <h2
            class="text-3xl lg:text-4xl font-medium tracking-tighter text-primary-700 flex items-center mb-10 gap-2"
          >
            Uma lente para a travessia
          </h2>
          <div class="space-y-6 text-primary-900 leading-relaxed">
            <p>
              Os quatro romances desta edição nos colocam diante de diferentes
              formas de violência contra a mulher e de diferentes formas de
              silenciamento da voz feminina. Para percorrer essa travessia,
              precisamos ter a "audácia de escutar", como propõe Carol Gilligan,
              e uma lente que reconheça as diferenças entre nós.
            </p>
            <p>É o que Dororidade, de Vilma Piedade, nos oferece.</p>
            <p>
              Publicado em 2017 pela Editora Nós, o livro propõe um conceito que
              nasce da percepção de que a sororidade, palavra que nomeia a
              solidariedade entre mulheres, precisa ser aprofundada para
              contemplar a experiência das mulheres negras.
            </p>
            <p>
              Dororidade é o eixo conceitual desta edição: uma lente para
              percorrer romances que narram experiências de mulheres de
              diferentes países, raças, classes e contextos. Porque construir um
              fortalecimento coletivo entre mulheres exige aprender a escutar as
              dores que diferem das nossas, reconhecê-las como reais e deixar
              que ampliem nossa consciência e nossa capacidade de agir juntas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- HISTÓRIAS QUE NOS ATRAVESSAM -->
    <section class="mx-auto py-20 lg:py-32 bg-primary-50">
      <div
        class="px-4 max-w-5xl px-4 sm:px-6 lg:px-8 space-y-6 mx-auto space-y-6"
      >
        <h2
          class="text-3xl lg:text-4xl mb-10 font-medium tracking-tighter text-primary-700 flex items-center gap-2"
        >
          Histórias que nos atravessam e nos conectam
        </h2>

        <div class="space-y-6 text-primary-900 leading-relaxed">
          <p>
            A escolha dos livros foi visceral e extremamente ousada. Cada livro
            desta edição nos coloca diante de uma forma de violência que existe
            de verdade, que tem endereço, que tem rosto, que muitas vezes tem o
            rosto de alguém conhecido.
          </p>
          <p>
            Reconhecemos que a igualdade de gênero não está apenas nos salários,
            cargos e representatividade. A violência é um fenômeno estrutural
            que atravessa tudo isso e afeta diretamente a autonomia, carreira,
            saúde e participação política das mulheres.
          </p>
          <p>
            Começamos onde a violência tem início com mais frequência: dentro de
            casa, dentro do vínculo, dentro do amor que machuca sem pedir
            licença e se repete, mesmo sem querer. Atravessamos a infância
            interrompida, a memória que a morte do agressor não apaga, o corpo
            feminino reduzido a mercadoria. E chegamos à distopia, não como fuga
            do real, mas como radicalização dele.
          </p>
          <p>
            Enfrentar dilemas do mundo real também é papel das lideranças
            femininas, que precisam lidar com a solidão, a exigência de
            sustentar emocionalmente relações, de navegar no caos e de bater
            metas, mesmo tendo que “abater a saúde mental” dos liderados.
          </p>
          <p>
            Entre esses quatro livros, há uma progressão que não é só literária.
            É a progressão de um mundo que aprendeu a conviver com o sofrimento
            das mulheres como se fosse inevitável. A literatura recusa esse
            conformismo. Ela nos devolve a capacidade de imaginar, criar, pensar
            e transformar.
          </p>
        </div>
      </div>
    </section>

    <!-- AS MEDIADORAS -->
    <section
      class="px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto space-y-10 py-20 lg:py-32"
    >
      <h2
        class="text-3xl lg:text-4xl font-medium tracking-tighter text-center font-medium text-primary-700 gap-2 pb-10"
      >
        As mediadoras
      </h2>

      <div class="grid md:grid-cols-2 gap-32 items-start">
        <div class="flex flex-col space-y-4">
          <Image
            src={mediadoraFlavia}
            alt="Flavia Abade"
            width="500"
            height="600"
            class="rounded-lg"
          />
          <h3 class="text-lg font-semibold">Flavia Abade</h3>
          <p class="text-primary-900 leading-relaxed">
            Educadora desde sempre, mãe de dois meninos, esposa apaixonante,
            amiga leal, psicóloga com graduação e mestrado pela UFMG e doutorado
            em Psicologia pela PUCMINAS. Atuei como gestora acadêmica no ensino
            superior em diversos cursos, inclusive como diretora acadêmica de
            medicina. Sou mineira, de BH. Gosto muito de ler, escrever, viajar,
            sou apaixonada pela aprendizagem e tenho dois certificados de
            atualização internacionais: em Educação pela Finland University e em
            Ciência do Bem-estar pela Yale University.
          </p>
        </div>

        <div class="flex flex-col space-y-4">
          <Image
            src={mediadoraRenata}
            alt="Renata Andreoni"
            width="500"
            height="600"
            class="rounded-lg"
          />
          <h3 class="text-lg font-semibold">Renata Andreoni</h3>
          <p class="text-primary-900 leading-relaxed">
            Mulher privilegiada, mas com muitas vulnerabilidades. Educadora,
            comunicóloga, historiadora e doutora em Comunicação
            (PUCRS/Sorbonne-Paris IV). Empreendedora social e ativista na luta
            por equidade de gênero, raça e classe. Fundadora e presidente do
            Instituto ELAborar. Desde 2010, atuo na liderança de equipes e
            projetos de impacto em comunicação, educação, cultura e diversidade,
            articulando Ensino, Pesquisa e Extensão. Na minha trajetória, uno
            conhecimento acadêmico e propósito social, liderando iniciativas que
            conectam diferentes saberes, diálogo e ação para fortalecer
            comunidades e organizações mais plurais e sustentáveis.
          </p>
        </div>
      </div>
    </section>

    <!-- DEPOIMENTOS -->
    <section class="mx-auto py-20 lg:py-32 bg-primary-50">
      <div class="px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto space-y-10">
        <h2
          class="text-xl lg:text-4xl font-medium tracking-tighter text-primary-700 text-center"
        >
          O que as participantes dizem
        </h2>

        <p class="text-center text-primary-900 max-w-3xl mx-auto">
          Histórias, reflexões, conexões e pertencimento. Conheça a experiência
          de mulheres que participaram da primeira edição do Clube do Livro
          ELAborando Mulheridades.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          {
            testimonials.map((t) => (
              <div class="bg-white p-6 rounded-xl shadow-md flex flex-col">
                <p class="text-primary-600 font-semibold leading-relaxed italic mb-4">
                  {t.quote}
                </p>
                <p class="text-primary-900 leading-relaxed flex-1">{t.body}</p>
                <div class="pt-4 mt-auto">
                  <p class="font-semibold text-primary-700">{t.name}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- PAUSA & CUIDADO -->
    <section
      class="px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto space-y-6 py-20 lg:py-32"
    >
      <h2
        class="text-xl font-medium lg:text-4xl font-medium tracking-tighter text-primary-700 flex items-center gap-2 mb-10"
      >
        Leitura como caminho de cuidado e consciência
      </h2>

      <div class="space-y-6 text-primary-900 leading-relaxed">
        <p>
          Os livros que escolhemos para esta edição não são confortáveis, mas
          são necessários! Eles nos convidam a olhar para o que preferiríamos
          não ver, a nomear o que muitas vezes permanece sem nome, a reconhecer
          em personagens ficcionais experiências que são dolorosamente reais.
        </p>
        <p>
          Falar sobre violência a partir da literatura é uma escolha ética e
          cuidadosa. A ficção cria distância suficiente para que possamos nos
          aproximar do que dói. Ela nos oferece linguagem onde antes havia só
          silêncio, e comunidade onde antes havia isolamento.
        </p>
        <p>
          Cada encontro será um espaço de escuta, reflexão e partilha, sempre
          sob as lentes da Comunicologia e da Psicologia, com a Cartografia
          Literária como método de leitura relacional que observa como
          estruturas culturais, afetos e autonomia se entrelaçam nas
          experiências de mulheres de diferentes gerações, raças, classes,
          sexualidades e trajetórias de vida.
        </p>
      </div>
    </section>

    <!-- TRAVESSIA -->
    <section
      class="px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto space-y-6 pb-20 lg:pb-32"
    >
      <h2
        class="text-xl font-medium lg:text-4xl font-medium tracking-tighter text-primary-700 flex items-center gap-2 mb-10"
      >
        Um clube que também é travessia
      </h2>

      <div
        class="bg-white p-6 lg:p-8 rounded-xl shadow-sm space-y-6 text-primary-900 leading-relaxed"
      >
        <p>
          <span class="text-xl tracking-tight italic"
            >“As histórias conferem movimento à nossa vida interior e exterior.
            Elas abrem portas.”</span
          >
          <br />- Clarissa Pinkola Estés
        </p>

        <p>
          Na primeira edição, abrimos portas juntas. Percorremos o Brasil, a
          Nigéria, a França e a Turquia, percorremos casamentos, maternidades,
          trabalhos e silêncios. A literatura nos levou ao cinema, à música, à
          poesia e a tantas outras expressões artísticas, ampliando o olhar e
          tecendo conexões entre diferentes linguagens e culturas. Construímos
          uma rede de mulheres que leram, conversaram e se reconheceram.
        </p>

        <p>
          Na segunda edição, continuamos essa travessia. Agora com a coragem de
          nomear o que nos fere, de entender as estruturas que sustentam a
          violência, e de encontrar, na literatura e nas outras linguagens que
          ela convoca (o cinema, a música, o nosso cotidiano...), e umas nas
          outras, razões e forças para seguir.
        </p>

        <p>
          Mais do que conteúdo sobre os livros, os encontros oferecem um espaço
          de leitura que se transforma em prática de cuidado e reflexão, no qual
          as mulheres se fortalecem por meio da cultura e da escuta.
        </p>
        <p>
          O Clube ELAborando Mulheridades é um convite à PAUSA, à saúde e à
          ELAboração. E também, cada vez mais, um ato de emancipação e
          fortalecimento coletivo.
        </p>
      </div>
    </section>

    <!-- COMO FUNCIONA -->
    <section class="mx-auto py-20 lg:py-32 bg-primary-50">
      <div class="px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto space-y-6">
        <h2
          class="text-xl font-medium lg:text-4xl font-medium tracking-tighter text-primary-700 flex items-center gap-2"
        >
          Como funciona
        </h2>

        <div class="space-y-6 text-primary-900 leading-relaxed">
          <p>
            O Clube do Livro ELAborando Mulheridades acontecerá ao longo de 4
            meses, de agosto a novembro de 2026, com 1 livro por mês.
          </p>

          <p>
            Teremos 2 encontros ao vivo por mês, sempre às terças-feiras,
            segunda e última do mês, das 19h às 20h30. Todas as conversas
            ficarão gravadas e disponíveis de forma vitalícia.
          </p>

          <h3 class="font-semibold text-primary-700">
            Estrutura dos encontros
          </h3>
          <ul class="list-disc pl-4 space-y-1 mb-6">
            <li>Primeiro encontro – Leitura conjunta e partilha.</li>
            <li>
              Segundo encontro – Diálogo entre Psicologia e Comunicologia,
              integrando literatura, cinema, música e outras expressões
              artísticas, com a Cartografia Literária como método de leitura
              relacional.
            </li>
          </ul>
          <p>
            O Cluble é virtual, mas poderão ser marcados encontros presenciais
            adicionais nas cidades de Belo Horizonte/MG e em Porto Alegre/RS.
          </p>
        </div>
      </div>
    </section>

    <!-- MATERIAIS -->
    <section
